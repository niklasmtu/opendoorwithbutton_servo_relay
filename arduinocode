#include <Servo.h>

// Inställningar för tider (millisekunder)
const int VANTA_UPPLASNING = 800;
const int DORR_OPPEN_TID = 5000;
const int STANGNINGS_TID = 2000;

// Pins
const int buttonPin = 2;
const int relayPin = 3;
const int servoPin = 9;

Servo myServo;

void setup() {
  pinMode(buttonPin, INPUT_PULLUP);
  pinMode(relayPin, OUTPUT);

  digitalWrite(relayPin, LOW); 

  myServo.attach(servoPin);
  myServo.write(0);

  Serial.begin(9600);
}

void loop() {
  if (digitalRead(buttonPin) == LOW) {
    oppnaDorr();
  }
}

void oppnaDorr() {
  Serial.println("Låser upp...");
  digitalWrite(relayPin, HIGH); 

  delay(VANTA_UPPLASNING);

  Serial.println("Öppnad dörren...");
  myServo.write(90);

  delay(DORR_OPPEN_TID);

  Serial.println("Stänger dörren...");
  myServo.write(0);

  delay(STANGNINGS_TID);

  Serial.println("Låser dörren.");
  digitalWrite(relayPin, LOW);
}

